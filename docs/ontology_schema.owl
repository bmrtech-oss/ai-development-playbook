<?xml version="1.0"?>
<rdf:RDF xmlns="http://example.org/ontology/"
     xml:base="http://example.org/ontology/"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#">

  <owl:Ontology rdf:about="http://example.org/ontology/"/>

  <owl:Class rdf:about="http://example.org/ontology/WarrantyClaim"/>
  <owl:Class rdf:about="http://example.org/ontology/InvoiceClaim"/>
  <owl:Class rdf:about="http://example.org/ontology/Product"/>

  <owl:DatatypeProperty rdf:about="http://example.org/ontology/claimText">
    <rdfs:domain rdf:resource="http://example.org/ontology/WarrantyClaim"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://example.org/ontology/confidence">
    <rdfs:domain rdf:resource="http://example.org/ontology/WarrantyClaim"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="http://example.org/ontology/relatedEntity">
    <rdfs:domain rdf:resource="http://example.org/ontology/WarrantyClaim"/>
    <rdfs:range rdf:resource="http://example.org/ontology/Product"/>
  </owl:ObjectProperty>

</rdf:RDF>
