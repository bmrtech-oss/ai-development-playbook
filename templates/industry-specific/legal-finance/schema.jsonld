    "Audit trail"
  ],
  "step": [
    {
      "@type": "HowToStep",
      "name": "Normalize documents and references",
      "text": "Structure agreements, regulations, and financial statements into a machine-readable representation for deterministic analysis."
    },
    {
      "@type": "HowToStep",
      "name": "Apply rule-based verification",
      "text": "Use Datalog or deterministic logic to assert facts, identify inconsistencies, and verify citations against source evidence."
    },
    {
      "@type": "HowToStep",
      "name": "Validate structured output",
      "text": "Only accept inference results that satisfy the output schema and preserve traceable provenance metadata."
    },
    {
      "@type": "HowToStep",
      "name": "Cache repeatable queries",
