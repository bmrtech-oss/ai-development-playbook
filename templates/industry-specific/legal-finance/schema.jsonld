{
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "Legal / Finance Fact-Checking Recipe",
  "description": "A deterministic AI recipe for high-precision legal and financial fact verification using Datalog patterns and audit-ready outputs.",
  "keywords": ["legal", "finance", "fact-checking", "Datalog", "deterministic", "audit"],
